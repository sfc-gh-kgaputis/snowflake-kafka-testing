SCALA_VERSION=2.13
KAFKA_VERSION=3.9.1

# Snowflake Kafka Connector — uncomment ONE version:
# v3.x standard connector (SnowflakeSinkConnector)
SNOWFLAKE_CONNECTOR_VERSION=3.5.3
# v4.x High Performance connector (SnowflakeStreamingSinkConnector)
#SNOWFLAKE_CONNECTOR_VERSION=4.0.0-rc8

# BouncyCastle FIPS JARs — required for encrypted private key authentication.
# Must match the connector version. Uncomment ONE pair:
# Connector >= 3.1.1 (including 4.x)
BC_FIPS_VERSION=2.1.0
BCPKIX_FIPS_VERSION=2.1.8
# Connector < 3.1.1
#BC_FIPS_VERSION=1.0.1
#BCPKIX_FIPS_VERSION=1.0.3
