{
  "name": "snowflake_avro_sensor_data",
  "config": {
    "connector.class": "com.snowflake.kafka.connector.SnowflakeSinkConnector",
    "tasks.max": "1",
    "topics": "sensor_data",
    "snowflake.database.name": "sfkafka_testing",
    "snowflake.schema.name": "raw",
    "snowflake.topic2table.map": "sensor_data:sensor_data",
    "snowflake.ingestion.method": "SNOWPIPE_STREAMING",
    "snowflake.enable.schematization": "true",
    "snowflake.url.name": "${SNOWFLAKE_HOST}:443",
    "snowflake.user.name": "${SNOWFLAKE_USER}",
    "snowflake.private.key": "${SNOWFLAKE_PRIVATE_KEY}",
    "snowflake.private.key.passphrase": "${SNOWFLAKE_PASSPHRASE}",
    "snowflake.role.name": "${SNOWFLAKE_ROLE}",
    "buffer.count.records": "50000",
    "buffer.flush.time": "1",
    "buffer.size.bytes": "16777216",
    "snowflake.streaming.enable.single.buffer": "true",
    "snowflake.streaming.max.client.lag": "5",
    "enable.streaming.client.optimization":"true",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",
    "value.converter.basic.auth.credentials.source": "USER_INFO",
    "value.converter.basic.auth.user.info": "test_user:Pa$$word",
    "consumer.override.partition.assignment.strategy": "org.apache.kafka.clients.consumer.CooperativeStickyAssignor",
    "snowflake.streaming.client.provider.override.map": "BDEC_PARQUET_COMPRESSION_ALGORITHM:zstd,ENABLE_SNOWPIPE_STREAMING_JMX_METRICS:true",
    "transforms": "addSchemaIdHeader",
    "transforms.addSchemaIdHeader.type": "com.snowflake.examples.kafka.smt.AddSchemaIdHeader"
  }
}